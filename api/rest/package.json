{
  "name": "@marvel-mock/api-rest",
  "version": "11.10.2",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node -r tsconfig-paths/register src/config/database/seeders/seeder.command.ts",
    "seed:clear": "ts-node -r tsconfig-paths/register src/config/database/seeders/seeder.command.ts --clear",
    "seed:refresh": "yarn seed:clear && yarn seed"
  },
  "dependencies": {
    "@nestjs/common": "^9.0.11",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^9.0.11",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "1.1.0",
    "@nestjs/passport": "^9.0.3",
    "@nestjs/platform-express": "^9.0.11",
    "@nestjs/swagger": "^6.0.5",
    "@nestjs/typeorm": "^9.0.1",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "axios": "^1.2.1",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "fuse.js": "^6.6.2",
    "joi": "^17.13.3",
    "mongodb": "^5.1.0",
    "mongoose": "^7.0.3",
    "mysql2": "^3.2.0",
    "nestjs-stripe": "^1.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "paypal-rest-sdk": "^1.8.1",
    "pg": "^8.10.0",
    "qs": "^6.11.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.5.6",
    "stripe": "^11.2.0",
    "typeorm": "^0.3.12"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.1",
    "@nestjs/testing": "^9.0.11",
    "@types/apollo-upload-client": "^19.0.0",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/classnames": "^2.3.4",
    "@types/express": "^4.17.13",
    "@types/extract-files": "^13.0.2",
    "@types/google.maps": "^3.58.1",
    "@types/hoist-non-react-statics": "^3.3.7",
    "@types/jest": "^28.1.7",
    "@types/js-yaml": "^4.0.9",
    "@types/minimatch": "^5.1.0",
    "@types/multer": "^1.4.7",
    "@types/node": "^18.7.6",
    "@types/overlayscrollbars": "^2.0.0",
    "@types/prop-types": "^15.7.15",
    "@types/quill": "^2.0.14",
    "@types/supertest": "^2.0.12",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^5.33.1",
    "@typescript-eslint/parser": "^5.33.1",
    "eslint": "^8.22.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "28.1.3",
    "prettier": "^2.7.1",
    "supertest": "^6.2.4",
    "ts-jest": "^28.0.8",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^4.7.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
